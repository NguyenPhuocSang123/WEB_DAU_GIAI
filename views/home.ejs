<%- include('partials') %>

<section class="container">
  <div style="margin: 40px 0;">
    <h1>Danh sach cac giai dau</h1>
    <p>Chon mot giai dau de xem chi tiet va dang ky.</p>
  </div>

  <% if (tournaments && tournaments.length > 0) { %>
    <div style="display: grid; grid-template-columns: repeat(auto-fill, minmax(300px, 1fr)); gap: 20px; margin-bottom: 40px;">
      <% tournaments.forEach(tournament => {
        const now = new Date();
        const isOpen = tournament.status === 'open' && now >= new Date(tournament.registrationOpenAt) && now <= new Date(tournament.registrationCloseAt);
        const isFull = tournament.totalTeams >= tournament.maxTeams;
        const closeDate = new Date(tournament.registrationCloseAt);
        const daysLeft = Math.ceil((closeDate - now) / (1000 * 60 * 60 * 24));
        let statusText = '';
        let statusColor = '';
        
        if (!isOpen && tournament.status !== 'open') {
          statusText = 'Chua mo';
          statusColor = '#999';
        } else if (isFull) {
          statusText = 'DA DAY - Khong con slot';
          statusColor = '#FF5252';
        } else if (isOpen) {
          if (daysLeft <= 1) {
            statusText = 'SAP DONG - Con ' + daysLeft + ' ngay';
            statusColor = '#FF9800';
          } else {
            statusText = 'DANG MO - Con ' + daysLeft + ' ngay';
            statusColor = '#4CAF50';
          }
        } else {
          statusText = 'Da dong dang ky';
          statusColor = '#FF6F00';
        }
      %>
        <a href="/tournament/<%= tournament._id %>" class="card" style="text-decoration: none; color: inherit; cursor: pointer; display: block; padding: 20px; transition: transform 0.2s; border-left: 5px solid <%= statusColor %>;">
          <div style="display: flex; justify-content: space-between; align-items: start; margin-bottom: 10px;">
            <h2 style="margin: 0; flex: 1;"><%= tournament.name %></h2>
            <span style="background-color: <%= statusColor %>; color: white; padding: 6px 12px; border-radius: 4px; font-size: 11px; font-weight: bold; white-space: nowrap; margin-left: 10px;">
              <%= isFull ? 'DAY' : (isOpen ? 'MO' : 'DONG') %>
            </span>
          </div>
          <p style="color: <%= statusColor %>; font-weight: bold; margin: 12px 0; font-size: 14px;">
            <%= statusText %>
          </p>
          <div style="display: grid; grid-template-columns: 1fr 1fr; gap: 10px; margin: 15px 0; padding: 10px 0; border-top: 1px solid #eee; border-bottom: 1px solid #eee;">
            <div>
              <small style="color: #999; font-size: 11px;">SO DOI DA DUYET</small>
              <p style="margin: 5px 0; font-weight: bold; font-size: 14px;"><%= tournament.displayCount %>/<%= tournament.maxTeams %></p>
            </div>
            <div>
              <small style="color: #999; font-size: 11px;">CON SLOT</small>
              <p style="margin: 5px 0; font-weight: bold; font-size: 14px; color: <%= isFull ? '#FF5252' : '#4CAF50' %>;"><%= tournament.maxTeams - tournament.totalTeams %></p>
            </div>
          </div>
          <p style="font-size: 12px; color: #666; margin: 10px 0;">
            Dong dang ky: <%= formatDate(tournament.registrationCloseAt) %>
          </p>
        </a>
      <% }) %>
    </div>
  <% } else { %>
    <div class="card" style="text-align: center; padding: 40px;">
      <p>Chua co giai dau nao. Vui long quay lai sau.</p>
    </div>
  <% } %>
</section>

<%- include('partials-footer') %>
